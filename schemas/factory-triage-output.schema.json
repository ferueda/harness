{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FactoryTriageOutput",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "route",
    "confidence",
    "rationale",
    "evidence",
    "questions",
    "reconsiderWhen",
    "suggestedNext"
  ],
  "properties": {
    "route": {
      "type": "string",
      "enum": ["ready-to-implement", "ready-to-plan", "needs-info", "wait-to-implement"]
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "path", "summary"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["tracker", "code", "docs", "test", "repo-state"]
          },
          "path": {
            "type": ["string", "null"],
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "questions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "reconsiderWhen": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "suggestedNext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "command", "artifact"],
      "properties": {
        "action": {
          "type": "string",
          "enum": ["implement-directly", "create-plan", "ask-human", "park"]
        },
        "command": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "artifact": {
          "type": ["string", "null"],
          "minLength": 1
        }
      }
    }
  }
}
