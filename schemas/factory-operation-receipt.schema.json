{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ferueda.dev/schemas/factory-operation-receipt.schema.json",
  "title": "Factory operation receipt",
  "$defs": {
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phaseRunId", "handler", "attempt", "causationEventId", "actionKey"],
      "properties": {
        "phaseRunId": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$" },
        "handler": { "enum": ["triageWorkItem", "producePlanCandidate", "reviewPlanCandidate", "produceImplementationCandidate", "reviewImplementationCandidate"] },
        "attempt": { "type": "integer", "minimum": 1 },
        "causationEventId": { "type": "string", "minLength": 1 },
        "actionKey": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["projectId", "workItemKey", "operation"],
      "properties": {
        "projectId": { "type": "string", "minLength": 1 },
        "workItemKey": { "type": "string", "minLength": 1 },
        "operation": { "$ref": "#/$defs/operation" }
      }
    }
  },
  "oneOf": [
    {
      "type": "object", "additionalProperties": false,
      "required": ["version", "projectId", "workItemKey", "operation", "outcome", "resultEventId"],
      "properties": {
        "version": { "const": 1 }, "projectId": { "type": "string", "minLength": 1 }, "workItemKey": { "type": "string", "minLength": 1 },
        "operation": { "$ref": "#/$defs/operation" }, "outcome": { "enum": ["executed", "recovered"] },
        "resultEventId": { "type": "string", "minLength": 1 }, "next": { "$ref": "#/$defs/request" }
      }
    },
    {
      "type": "object", "additionalProperties": false,
      "required": ["version", "projectId", "workItemKey", "operation", "outcome", "observedEventId"],
      "properties": {
        "version": { "const": 1 }, "projectId": { "type": "string", "minLength": 1 }, "workItemKey": { "type": "string", "minLength": 1 },
        "operation": { "$ref": "#/$defs/operation" }, "outcome": { "const": "stale" }, "observedEventId": { "type": "string", "minLength": 1 }
      }
    },
    {
      "type": "object", "additionalProperties": false,
      "required": ["version", "projectId", "workItemKey", "operation", "outcome", "observedEventId", "reason"],
      "properties": {
        "version": { "const": 1 }, "projectId": { "type": "string", "minLength": 1 }, "workItemKey": { "type": "string", "minLength": 1 },
        "operation": { "$ref": "#/$defs/operation" }, "outcome": { "const": "waiting" }, "observedEventId": { "type": "string", "minLength": 1 },
        "reason": { "enum": ["human", "plan-publication", "plan-merge", "pr-publication", "pr-merge", "complete", "failed", "stale-event"] }
      }
    }
  ]
}
