{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FactoryPlanningOutput",
  "type": "object",
  "additionalProperties": false,
  "required": ["outcome", "summary", "humanQuestions", "findingDecisions"],
  "properties": {
    "outcome": {
      "type": "string",
      "enum": ["draft-ready", "needs-human"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "humanQuestions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "findingDecisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["findingId", "decision", "rationale"],
        "properties": {
          "findingId": {
            "type": "string",
            "minLength": 1
          },
          "decision": {
            "type": "string",
            "enum": ["implement", "adapt", "decline"]
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
