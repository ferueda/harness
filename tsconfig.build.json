{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "outDir": "dist",
    "rootDir": ".",
    "sourceMap": true
  },
  "exclude": [
    "dist",
    "node_modules",
    ".harness",
    "scripts/**/*.ts",
    "test/**/*.ts",
    "**/*.test.ts",
    "vitest.config.ts"
  ]
}
