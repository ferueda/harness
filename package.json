{
  "name": "harness",
  "version": "0.0.0",
  "private": true,
  "bin": {
    "harness": "./dist/bin/harness.js"
  },
  "files": [
    "dist",
    "schemas",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "make check",
    "check:ci": "make check-ci",
    "check:plan": "oxfmt --check dev/plans && vitest run test/docs-contracts.test.ts",
    "check:v": "make check-v",
    "codex:proxy": "node scripts/codex-proxy.mjs",
    "fix": "make fix",
    "fix:plan": "oxfmt --write dev/plans",
    "format": "oxfmt --write bin lib providers scripts workflows test docs package.json tsconfig.json tsconfig.build.json vitest.config.ts .oxlintrc.json .oxfmtrc.json",
    "format:check": "oxfmt --check bin lib providers scripts workflows test docs package.json tsconfig.json tsconfig.build.json vitest.config.ts .oxlintrc.json .oxfmtrc.json",
    "lint": "oxlint -c .oxlintrc.json bin lib providers scripts workflows test vitest.config.ts",
    "lint:fix": "oxlint -c .oxlintrc.json --fix bin lib providers scripts workflows test vitest.config.ts",
    "prepare": "simple-git-hooks",
    "smoke:dist": "node scripts/smoke-dist.ts",
    "smoke:factory": "node scripts/smoke-factory.ts && node scripts/smoke-factory-grove.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@cursor/sdk": "1.0.23",
    "@ferueda/grove": "1.4.4",
    "@linear/sdk": "88.1.0",
    "@openai/codex-sdk": "0.144.6",
    "commander": "15.0.0",
    "inngest": "4.13.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@inngest/test": "1.0.0",
    "@types/node": "26.1.1",
    "inngest-cli": "1.37.0",
    "lint-staged": "17.0.8",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "simple-git-hooks": "2.13.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged && pnpm typecheck"
  },
  "lint-staged": {
    "{bin,lib,providers,scripts,workflows,test,docs}/**/*.{ts,js,json,md}": "pnpm exec oxfmt --write",
    "./{package.json,tsconfig.json,tsconfig.build.json,vitest.config.ts,.oxlintrc.json,.oxfmtrc.json}": "pnpm exec oxfmt --write",
    "{bin,lib,providers,scripts,workflows,test}/**/*.{ts,js}": "pnpm exec oxlint -c .oxlintrc.json --fix",
    "./vitest.config.ts": "pnpm exec oxlint -c .oxlintrc.json --fix"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.9.0"
}
